{
  "name": "@raffiniert-media-ag/payload-live-preview-inspector",
  "version": "1.0.0",
  "description": "Click a component in Payload's Live Preview iframe to scroll to and highlight the matching field in the admin panel.",
  "keywords": [
    "payload",
    "payload-cms",
    "payload-plugin",
    "plugin",
    "live-preview",
    "click-to-scroll",
    "cms"
  ],
  "author": "Raffiniert Media AG",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raffiniert-Media/payload-live-preview-inspector.git"
  },
  "bugs": {
    "url": "https://github.com/Raffiniert-Media/payload-live-preview-inspector/issues"
  },
  "homepage": "https://github.com/Raffiniert-Media/payload-live-preview-inspector#readme",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/exports/client.d.ts",
      "import": "./dist/exports/client.js",
      "default": "./dist/exports/client.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths --ignore \"**/*.test.ts\"",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "dev": "next dev dev --turbo",
    "dev:generate-importmap": "pnpm dev:payload generate:importmap",
    "dev:generate-types": "pnpm dev:payload generate:types",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload",
    "generate:importmap": "pnpm dev:generate-importmap",
    "generate:types": "pnpm dev:generate-types",
    "lint": "eslint",
    "lint:fix": "eslint ./src --fix",
    "prepare": "pnpm clean && pnpm build",
    "prepublishOnly": "pnpm clean && pnpm build",
    "test": "pnpm test:int && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:int": "vitest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@payloadcms/db-sqlite": "3.84.1",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@playwright/test": "1.58.2",
    "@swc-node/register": "1.10.9",
    "@swc/cli": "0.6.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "copyfiles": "2.4.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.23.0",
    "eslint-config-next": "16.2.6",
    "graphql": "^16.8.1",
    "happy-dom": "20.10.6",
    "next": "16.2.6",
    "open": "^10.1.0",
    "payload": "3.84.1",
    "prettier": "^3.4.2",
    "qs-esm": "8.0.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rimraf": "5.0.10",
    "sharp": "0.34.2",
    "sort-package-json": "^2.10.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "@payloadcms/ui": "^3.84.1",
    "payload": "^3.84.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@payloadcms/ui": {
      "optional": true
    },
    "payload": {
      "optional": true
    }
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  },
  "packageManager": "pnpm@10.17.1",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "undici@<7.28.0": "^7.28.0"
    }
  }
}
